{
  "rewrites": [
    {
      "source": "/api-proxy/(.*)",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/pepakraja/wr/:1"
    },
    { "source": "/api/bapenda/(.*)", "destination": "/api/bapenda" },
    {
      "source": "/bapenda/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/:path*"
    },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

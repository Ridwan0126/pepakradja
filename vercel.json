{
  "rewrites": [
    {
      "source": "/api/set-password",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/pepakraja/wr/set-password"
    },
    {
      "source": "/api/set-password/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/pepakraja/wr/set-password/:path*"
    },
    { "source": "/api/bapenda/(.*)", "destination": "/api/bapenda" },
    {
      "source": "/bapenda/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/:path*"
    },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/set-password/:path*",
      "headers": [
        { "key": "Referer", "value": "https://rpp.bapenda.jatengprov.go.id/" },
        { "key": "Origin", "value": "https://rpp.bapenda.jatengprov.go.id/" }
      ]
    }
  ]
}

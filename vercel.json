{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/bapenda-api/(.*)",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan-dev/api/$1"
    },
    {
      "source": "/bapenda-sptrd/(.*)",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/$1"
    }
  ]
}

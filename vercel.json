{
  "rewrites": [
    {
      "source": "/api-proxy/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/pepakraja/wr/:path*"
    },
    {
      "source": "/api-reset/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/pepakraja/wr/:path*"
    },
    {
      "source": "/api/set-password",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/pepakraja/wr/set-password"
    },
    {
      "source": "/bapenda/:path*",
      "destination": "https://rpp.bapenda.jatengprov.go.id/penatausahaan/api/:path*"
    },
    {
      "source": "/api/bapenda/(.*)",
      "destination": "/api/bapenda"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api-reset/(.*)",
      "headers": [
        { "key": "Referer", "value": "https://rpp.bapenda.jatengprov.go.id/" },
        { "key": "Origin", "value": "https://rpp.bapenda.jatengprov.go.id" }
      ]
    },
    {
      "source": "/api-proxy/(.*)",
      "headers": [
        { "key": "Referer", "value": "https://rpp.bapenda.jatengprov.go.id/" },
        { "key": "Origin", "value": "https://rpp.bapenda.jatengprov.go.id" }
      ]
    }
  ]
}
